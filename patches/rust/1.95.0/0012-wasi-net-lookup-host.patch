-pub fn lookup_host(_host: &str, _port: u16) -> io::Result<LookupHost> {
-    unsupported()
+pub fn lookup_host(host: &str, port: u16) -> io::Result<LookupHost> {
+    let node = CString::new(host).map_err(|_| {
+        io::Error::new(io::ErrorKind::InvalidInput, "host contains an interior NUL byte")
+    })?;
+    let service = CString::new(port.to_string()).map_err(|_| {
+        io::Error::new(io::ErrorKind::InvalidInput, "service contains an interior NUL byte")
+    })?;
+
+    let hints = YurtAddrInfo {
+        ai_flags: 0,
+        ai_family: YURT_AF_INET,
+        ai_socktype: YURT_SOCK_STREAM,
+        ai_protocol: 0,
+        ai_addrlen: 0,
+        ai_addr: crate::ptr::null_mut(),
+        ai_canonname: crate::ptr::null_mut(),
+        ai_next: crate::ptr::null_mut(),
+    };
+    let mut res: *mut YurtAddrInfo = crate::ptr::null_mut();
+
+    let rc = unsafe {
+        getaddrinfo(
+            node.as_ptr(),
+            service.as_ptr(),
+            &hints as *const YurtAddrInfo,
+            &mut res as *mut *mut YurtAddrInfo,
+        )
+    };
+    if rc != 0 {
+        return Err(io::Error::new(io::ErrorKind::Uncategorized, "host lookup failed"));
+    }
+
+    let mut addrs = vec::Vec::new();
+    let mut cur = res;
+    while !cur.is_null() {
+        let ai = unsafe { &*cur };
+        if ai.ai_family == YURT_AF_INET
+            && !ai.ai_addr.is_null()
+            && (ai.ai_addrlen as usize) >= mem::size_of::<YurtSockAddrIn>()
+        {
+            let raw = unsafe { &*(ai.ai_addr as *const YurtSockAddrIn) };
+            addrs.push(SocketAddr::from((
+                Ipv4Addr::from(raw.sin_addr.s_addr.to_ne_bytes()),
+                u16::from_be(raw.sin_port),
+            )));
+        }
+        cur = ai.ai_next;
+    }
+    unsafe { freeaddrinfo(res) };
+
+    if addrs.is_empty() {
+        return Err(io::Error::NO_ADDRESSES);
+    }
+
+    Ok(LookupHost(addrs.into_iter()))
 }
