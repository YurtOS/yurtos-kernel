+fn spawn_command_with_stdio(
+    cmd: &Command,
+    default: Stdio,
+    needs_stdin: bool,
+) -> io::Result<(Process, StdioPipes)> {
+    let mut actions = PosixSpawnFileActions::zeroed();
+    let actions_ptr = &mut actions as *mut PosixSpawnFileActions;
+    unsafe { cvt_spawn(posix_spawn_file_actions_init(actions_ptr))?; }
+
+    let mut parent_stdin = None;
+    let mut parent_stdout = None;
+    let mut parent_stderr = None;
+    let mut close_after_spawn = Vec::new();
+    let mut close_on_error = Vec::new();
+
+    let setup_result = (|| {
+        setup_stdin(
+            cmd.stdin.as_ref().unwrap_or(if needs_stdin { &default } else { &Stdio::Null }),
+            actions_ptr,
+            &mut parent_stdin,
+            &mut close_after_spawn,
+            &mut close_on_error,
+        )?;
+        setup_output(
+            cmd.stdout.as_ref().unwrap_or(&default),
+            actions_ptr,
+            1,
+            &mut parent_stdout,
+            &mut close_after_spawn,
+            &mut close_on_error,
+        )?;
+        setup_output(
+            cmd.stderr.as_ref().unwrap_or(&default),
+            actions_ptr,
+            2,
+            &mut parent_stderr,
+            &mut close_after_spawn,
+            &mut close_on_error,
+        )?;
+        Ok(())
+    })();
+
+    if let Err(err) = setup_result {
+        unsafe { posix_spawn_file_actions_destroy(actions_ptr); }
+        for fd in close_on_error {
+            close_ignoring_error(fd);
+        }
+        return Err(err);
+    }
+
+    let spawn_result = spawn_command(cmd, actions_ptr);
+    unsafe { posix_spawn_file_actions_destroy(actions_ptr); }
+
+    for fd in close_after_spawn {
+        close_ignoring_error(fd);
+    }
+
+    match spawn_result {
+        Ok((process, _)) => Ok((process, StdioPipes {
+            stdin: parent_stdin.map(pipe_from_raw_fd),
+            stdout: parent_stdout.map(pipe_from_raw_fd),
+            stderr: parent_stderr.map(pipe_from_raw_fd),
+        })),
+        Err(err) => {
+            for fd in close_on_error {
+                close_ignoring_error(fd);
+            }
+            Err(err)
+        }
+    }
 }

