+const WNOHANG: i32 = 1;
+
+unsafe extern "C" {
+    fn posix_spawnp(
+        pid: *mut i32,
+        file: *const c_char,
+        file_actions: *const (),
+        attrp: *const (),
+        argv: *const *mut c_char,
