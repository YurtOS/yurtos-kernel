+
+fn cstring_from_os(value: &OsStr) -> io::Result<CString> {
+    CString::new(value.as_bytes())
+        .map_err(|_| io::Error::new(io::ErrorKind::InvalidInput, "nul byte in process argument"))
+}
+
+fn cstring_vec(values: &[OsString]) -> io::Result<Vec<CString>> {
+    values.iter().map(|value| cstring_from_os(value)).collect()
+}
+
+fn wait_for_pid(pid: i32, options: i32) -> io::Result<Option<ExitStatus>> {
+    let mut status = 0;
+    let rc = unsafe { waitpid(pid, &mut status, options) };
+    if rc < 0 {
+        return Err(io::Error::last_os_error());
+    }
+    if rc == 0 {
+        return Ok(None);
+    }
+    Ok(Some(ExitStatus(status)))
+}
+
+fn nonzero(value: i32) -> NonZero<i32> {
+    NonZero::new(value).unwrap_or_else(|| NonZero::new(1).unwrap())
+}
