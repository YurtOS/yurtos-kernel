+struct CommandEnvp {
+    _entries: Vec<CString>,
+    ptrs: Vec<*mut c_char>,
+}
+
+impl CommandEnvp {
+    fn capture(cmd: &Command) -> io::Result<Option<Self>> {
+    let Some(captured) = cmd.env.capture_if_changed() else {
+        return Ok(None);
+    };
+
+    let mut entries = Vec::new();
+    for (mut key, value) in captured {
+        key.push("=");
+        key.push(&value);
+        entries.push(cstring_from_os(&key)?);
+    }
+
+    let mut envp: Vec<*mut c_char> =
+        entries.iter().map(|entry| entry.as_ptr() as *mut c_char).collect();
+    envp.push(ptr::null_mut());
+    Ok(Some(Self { _entries: entries, ptrs: envp }))
+    }
+
+    fn as_ptr(&self) -> *const *mut c_char {
+        self.ptrs.as_ptr()
+    }
+}
