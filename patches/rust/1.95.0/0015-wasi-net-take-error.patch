@@ -118,0 +122,16 @@
+fn tcp_take_error(fd: RawFd) -> io::Result<Option<io::Error>> {
+    let mut error: c_int = 0;
+    let mut len = mem::size_of::<c_int>() as YurtSockLen;
+    let rc = unsafe {
+        getsockopt(fd as i32, YURT_SOL_SOCKET, YURT_SO_ERROR, &mut error, &mut len)
+    };
+    if rc != 0 {
+        return Err(io::Error::last_os_error());
+    }
+    if error == 0 {
+        Ok(None)
+    } else {
+        Ok(Some(io::Error::from_raw_os_error(error)))
+    }
+}
